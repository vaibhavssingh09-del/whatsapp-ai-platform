# ============================================================================
# Copy this file to backend/.env and fill in real values.
# Every variable here is explained in detail in README.md > Environment Variables.
# ============================================================================

# --- App ---
ENVIRONMENT=development
DEBUG=true

# --- Security ---
# Generate with: python3 -c "import secrets; print(secrets.token_urlsafe(48))"
JWT_SECRET_KEY=REPLACE_WITH_A_LONG_RANDOM_SECRET

# --- CORS (comma-separated list is NOT supported by pydantic-settings list parsing
# from .env directly; if you need multiple origins, set CORS_ORIGINS as a JSON
# array string, e.g. ["http://localhost:5173","https://your-dashboard.onrender.com"])
CORS_ORIGINS=["http://localhost:5173"]

# --- MongoDB Atlas ---
# Get this from Atlas -> Database -> Connect -> Drivers -> Python
MONGO_URI=mongodb+srv://<username>:<password>@<cluster-url>/?retryWrites=true&w=majority
MONGO_DB_NAME=whatsapp_ai_platform

# --- OpenAI ---
OPENAI_API_KEY=sk-REPLACE_ME
OPENAI_MODEL=gpt-4o-mini

# --- Meta / WhatsApp Cloud API ---
# App Secret: Meta App Dashboard -> App Settings -> Basic -> App Secret
META_APP_SECRET=REPLACE_ME
# Verify Token: any string YOU choose, entered again in the Meta webhook config screen
META_VERIFY_TOKEN=REPLACE_WITH_ANY_SECRET_STRING_YOU_CHOOSE
WHATSAPP_API_VERSION=v20.0

# --- Media ---
MEDIA_STORAGE_DIR=./media_storage
MAX_MEDIA_SIZE_MB=16

# --- Agent behavior ---
AGENT_MAX_RETRIES=2
AGENT_LOW_CONFIDENCE_THRESHOLD=0.55

# --- Logging ---
LOG_LEVEL=INFO
