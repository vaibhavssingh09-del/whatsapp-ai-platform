# In local dev, leave this as /api/v1 — Vite's dev server proxies it to the
# backend (see vite.config.js). In production behind the same Render service
# or a shared reverse proxy, keep it as /api/v1 too. Only change this if the
# frontend and backend are deployed to fully separate origins with no proxy,
# in which case set the full backend URL, e.g. https://api.yourapp.com/api/v1
VITE_API_BASE_URL=/api/v1
